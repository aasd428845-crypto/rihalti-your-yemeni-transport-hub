# Supabase (required for web app and API server)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API Server URL (set this in Vercel environment variables after deploying the API on Railway)
# Example: https://wasal-api.up.railway.app
VITE_API_BASE_URL=

# SMS / Traccar
TRACCAR_TOKEN=your-traccar-token
